{
  "name": "research-assistant",
  "version": "1.0.0",
  "description": "智能物联感知与处理 - 个人研究门户",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "fetch": "node src/fetchers/papers.js",
    "report": "node src/reporters/progress.js",
    "test:venue": "node scripts/test-venue-matcher.js",
    "test:filter": "node scripts/test-paper-filter.js",
    "test:progress": "node scripts/test-progress-delivery.js",
    "test:fetch": "node scripts/test-fetch-venue-integration.js",
    "test": "npm run test:venue && npm run test:fetch && npm run test:filter && npm run test:progress",
    "validate:config": "node scripts/validate-config.js",
    "filter": "node src/utils/paperFilter.js",
    "filter:top": "node src/utils/paperFilter.js --top-only",
    "filter:high": "node src/utils/paperFilter.js --high-only",
    "scheduler:start": "node src/scheduler/index.js start",
    "scheduler:once": "node src/scheduler/index.js once",
    "scheduler:status": "node src/scheduler/index.js status"
  },
  "keywords": ["research", "IoT", "perception", "papers"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "node-cron": "^3.0.3"
  }
}
