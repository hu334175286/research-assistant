generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Paper {
  id            String   @id @default(cuid())
  title         String
  year          Int?
  source        String?
  tags          String?
  summaryJson   String?
  venueTier     String   @default("unknown")
  venueMatchedBy String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  experiments   Experiment[] // 基于该文献的实验
}

model Experiment {
  id                     String   @id @default(cuid())
  name                   String
  status                 String   @default("draft") // draft, running, completed, failed, archived
  hypothesis             String?
  configJson             String?  // 实验配置快照（超参、随机种子等）
  metricsJson            String?  // 关键指标结果
  logsJson               String?  // 运行日志/中间结果
  conclusion             String?
  tags                   String?  // 标签，逗号分隔
  
  // 关联文献（基于哪篇论文的idea）
  sourcePaperId          String?
  sourcePaper            Paper?   @relation(fields: [sourcePaperId], references: [id], onDelete: SetNull)
  
  // 数据集关联
  datasetId              String?
  dataset                Dataset? @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  datasetVersionSnapshot String?  // 数据集版本快照
  
  // 代码/环境快照
  codeSnapshot           String?  // 代码版本（git commit/hash）
  environment            String?  // 环境信息（Python版本、关键包版本）
  
  // 时间戳
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([datasetId])
  @@index([sourcePaperId])
  @@index([status])
  @@index([createdAt])
}

model Dataset {
  id          String         @id @default(cuid())
  name        String
  type        String?
  source      String?
  license     String?
  tags        String?
  storagePath String?
  version     String?
  sizeBytes   Int?
  fileHash    String?
  note        String?
  metricsJson String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  experiments Experiment[]
  splits      DatasetSplit[]
}

model DatasetSplit {
  id        String   @id @default(cuid())
  datasetId String
  split     String
  count     Int?
  ratio     Float?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, split])
  @@index([datasetId])
}

model Insight {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String?
  text       String
  tags       String?
  createdAt  DateTime @default(now())
}

model Task {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("todo")
  dueAt     DateTime?
  priority  Int      @default(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyReport {
  id          String   @id @default(cuid())
  dayKey       String   @unique
  contentShort String?
  contentFull  String?
  generatedAt  DateTime @default(now())
}

model WeeklyReport {
  id         String   @id @default(cuid())
  weekKey    String   @unique
  contentMd  String?
  generatedAt DateTime @default(now())
}
