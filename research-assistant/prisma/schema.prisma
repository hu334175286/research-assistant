generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Paper {
  id            String   @id @default(cuid())
  title         String
  year          Int?
  source        String?
  tags          String?
  summaryJson   String?
  venueTier     String   @default("unknown")
  venueMatchedBy String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Experiment {
  id                     String   @id @default(cuid())
  name                   String
  hypothesis             String?
  configJson             String?
  metricsJson            String?
  conclusion             String?
  datasetId              String?
  datasetVersionSnapshot String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  dataset Dataset? @relation(fields: [datasetId], references: [id], onDelete: SetNull)

  @@index([datasetId])
}

model Dataset {
  id          String         @id @default(cuid())
  name        String
  type        String?
  source      String?
  license     String?
  tags        String?
  storagePath String?
  version     String?
  sizeBytes   Int?
  fileHash    String?
  note        String?
  metricsJson String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  experiments Experiment[]
  splits      DatasetSplit[]
}

model DatasetSplit {
  id        String   @id @default(cuid())
  datasetId String
  split     String
  count     Int?
  ratio     Float?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, split])
  @@index([datasetId])
}

model Insight {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String?
  text       String
  tags       String?
  createdAt  DateTime @default(now())
}

model Task {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("todo")
  dueAt     DateTime?
  priority  Int      @default(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyReport {
  id          String   @id @default(cuid())
  dayKey       String   @unique
  contentShort String?
  contentFull  String?
  generatedAt  DateTime @default(now())
}

model WeeklyReport {
  id         String   @id @default(cuid())
  weekKey    String   @unique
  contentMd  String?
  generatedAt DateTime @default(now())
}
